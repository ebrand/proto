# Stytch B2B public (frontend) token from the Stytch dashboard.
# Public tokens are safe to expose in the browser. Do NOT put the Stytch secret
# key or the Google client secret here — those are server-side only.
VITE_STYTCH_PUBLIC_TOKEN=public-token-test-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Base URL of the Proto .NET API (Proto.Api). Defaults to the API's dev `http`
# launch profile if unset.
VITE_API_BASE_URL=http://localhost:5070
