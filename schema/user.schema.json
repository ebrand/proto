{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "proto/user.schema.json",
  "title": "User",
  "type": "object",
  "required": ["id", "tenantId", "email", "displayName", "status", "tenantRole", "createdAt"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string", "format": "uuid" },
    "email": { "type": "string", "format": "email" },
    "displayName": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["invited", "active", "deactivated"] },
    "tenantRole": { "type": "string", "enum": ["admin", "member"], "description": "Tenant-level admin vs ordinary member; distinct from per-prototype roles" },
    "identities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["provider", "stytchUserId"],
        "additionalProperties": false,
        "properties": {
          "provider": { "type": "string", "description": "OAuth IdP, e.g. google, microsoft, github" },
          "providerSubject": { "type": "string" },
          "stytchUserId": { "type": "string" }
        }
      }
    },
    "lastLoginAt": { "type": ["string", "null"], "format": "date-time" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
